# ServerCrate restic-toolkit — env template
# Copy to .env in the repo root and fill in.

# REQUIRED: Restic repository URL.
# ServerCrate format: sftp:user@vault.servercrate.net:22150:/repo
# Other backends:
#   sftp:user@host:port:/path
#   b2:bucketname:path
#   s3:s3.amazonaws.com/bucket/path
RESTIC_REPOSITORY=

# REQUIRED: path to a 0600 file containing the repo passphrase.
# Generate one with: openssl rand -base64 48 > /etc/restic.pw && chmod 600 /etc/restic.pw
RESTIC_PASSWORD_FILE=/etc/restic.pw

# What to back up — space-separated list of paths.
BACKUP_PATHS="/home /etc /srv /var/lib /opt"

# What to skip — paths in this file are excluded.
EXCLUDE_FILE=/etc/restic.exclude

# Cache dir (Restic deduplication cache). 1–2 GB typical.
RESTIC_CACHE_DIR=/var/cache/restic

# Tags applied to every snapshot — helpful for filtering later.
BACKUP_TAGS="auto,host:$(hostname -s)"

# Retention (see sc-prune.sh) — keep within these windows.
KEEP_HOURLY=24
KEEP_DAILY=7
KEEP_WEEKLY=4
KEEP_MONTHLY=12
KEEP_YEARLY=3

# Verify cadence — what fraction of pack data to read-verify each run.
VERIFY_SUBSET=5%
